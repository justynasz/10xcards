---
import Layout from "@/layouts/Layout.astro";
import DeleteAccountForm from "@/components/auth/DeleteAccountForm";

const { user } = Astro.locals;
const error = Astro.url.searchParams.get("error");
---

<Layout title="Account">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Account
      </h1>
      <p class="mb-6 text-center text-blue-100/80">
        Signed in as <span class="font-semibold text-white">{user?.email}</span>
      </p>

      <div class="rounded-xl border border-red-500/30 bg-red-950/20 p-4">
        <h2 class="mb-1 text-sm font-semibold text-red-300">Danger zone</h2>
        <p class="mb-4 text-xs text-red-200/70">
          Deleting your account permanently removes your account and all your flashcards. This cannot be undone.
        </p>
        <DeleteAccountForm serverError={error} client:load />
      </div>

      <p class="mt-4 text-center text-sm text-blue-100/60">
        <a href="/dashboard" class="text-purple-300 hover:underline">Back to dashboard</a>
      </p>
    </div>
  </div>
</Layout>
